@echo off
setlocal enabledelayedexpansion

set "directory=%cd%"

for %%F in ("%directory%\*.*") do (
    set "filename=%%~nF"
    set "extension=%%~xF"
    
    if not "!extension:~-3!"=="" (
        if exist "%%F" (
            set "new_extension=!extension!!extension:~-3!"
            ren "%%F" "!filename!!new_extension!"
        ) else (
            echo File not found: "%%F"
        )
    )
)

echo Done.
pause
